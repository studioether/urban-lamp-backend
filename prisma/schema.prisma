// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_PRISMA_URL")
  // directUrl = env("POSTGRES_URL_NON_POOLING")
}


model User{
 id   Int @id @default(autoincrement())
 username   String @unique()
 email  String @unique()
 password   String @unique()
 //single user to many posts
 reviews  Review[] @relation(name: "UserPosts")
 responses Comments[]
 bookmarks  Review[] @relation(name: "UserBookmarks")
 createdAt    DateTime @default(now())
}

model Review{
  id  Int @id @default(autoincrement())
  content   String
  author  User?  @relation(name: "UserPosts", fields: [authorId], references: [id])
  authorId  Int?
  bookmarked  User? @relation(name: "UserBookmarks", fields: [bookmarkedByUser], references: [id])
  bookmarkedByUser  Int?
  upvotes   Int @default(0)
  downvotes   Int @default(0)
  comments    Comments[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Comments{
  id Int @id @default(autoincrement())
  review Review? @relation(fields: [reviewId], references: [id])
  reviewId Int
  author  User?  @relation(fields: [authorId], references: [id])
  authorId  Int?
  createdAt    DateTime @default(now())
}

